# Python virtual environment (regenerate with: py -3.11 -m venv .venv)
.venv/

# Bundled llama.cpp binaries (download from github.com/ggml-org/llama.cpp/releases)
llama_bin/
llama_bin_cuda/

# Runtime artifacts
server.log
chats.db
chats.db-wal
chats.db-shm
__pycache__/
*.pyc

# Models are cached in ~/.cache/huggingface, never committed
*.gguf
